rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 3. Path Variable Hardening & Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 20 &&
             data.displayName is string && data.displayName.size() <= 100;
    }

    function isValidFriend(data) {
      return data.uid is string && data.status in ['pending', 'accepted'];
    }

    function isValidPhoto(data) {
      return data.senderId == request.auth.uid &&
             data.imageUrl is string && data.imageUrl.size() <= 800000 &&
             data.recipientIds is list && data.recipientIds.size() <= 50;
    }

    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow get: if isSignedIn();
      // 8. Secure List Queries (The "Query Enforcer")
      allow list: if isSignedIn() && request.query.limit <= 20;
      
      allow create: if isOwner(userId) && isValidUser(incoming()) &&
                      incoming().keys().hasAll(['uid', 'username', 'createdAt']) &&
                      incoming().createdAt == request.time;
      
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
                      incoming().uid == existing().uid &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time;
      
      // Friends subcollection
      match /friends/{friendId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(friendId) && isValidFriend(incoming());
      }
    }

    // Photos collection
    match /photos/{photoId} {
      // 8. Secure List Queries
      allow get: if isSignedIn() && (
        request.auth.uid == existing().senderId || 
        request.auth.uid in existing().recipientIds
      );
      
      allow list: if isSignedIn() && (
        request.auth.uid == existing().senderId || 
        request.auth.uid in existing().recipientIds
      );

      allow create: if isSignedIn() && isValidPhoto(incoming()) &&
                      incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && (
        // Action: React
        (incoming().diff(existing()).affectedKeys().hasOnly(['reactions']) && 
         incoming().reactions.keys().hasAll(existing().reactions.keys())) ||
        
        // Action: Edit Caption (Sender only)
        (request.auth.uid == existing().senderId && 
         incoming().diff(existing()).affectedKeys().hasOnly(['caption']))
      );
    }
  }
}
